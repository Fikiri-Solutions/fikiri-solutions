# Copy to frontend/.env.local and adjust. Vite reads only vars prefixed with VITE_.
# Never commit .env.local or paste real keys into chat/CI logs.

# Backend (default on localhost: http://localhost:5000/api)
# VITE_API_URL=http://localhost:5000/api

# Supabase browser client (publishable anon key only — not the service role key)
# VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Fikiri marketing site assistant (first-party /api/site/chat — no tenant API key).
# Copy to frontend/.env.local. Backend flags (FIKIRI_SITE_BOT_*) belong in root .env / Render.
# Soft launch: widget on, persist off on backend. Sales-review: backend FIKIRI_SITE_BOT_PERSIST_TRANSCRIPTS=1
VITE_SITE_CHAT_WIDGET_ENABLED=true

# Client demo safety (set on Vercel for tomorrow's demo build)
# VITE_DEMO_SAFE_MODE=true          # Hides /ai, Chatbot Builder, Services nav; gates unfinished routes
# VITE_DEMO_EMAIL_AI_ENABLED=true   # Only after: python3 scripts/demo_openai_health_check.py + inbox rehearsal

# Dev-only: show Copy button in widget header (also on by default in Vite dev / localhost).
# VITE_SITE_CHAT_DEV_TOOLS=true

# Tenant embed product (client sites / install flow) — unchanged:
# Local dev: optional if you already opened /install — key is reused from localStorage (fikiri-public-api-key).
# VITE_CHATBOT_API_KEY=your-key-from-dashboard-or-install

# Optional: override SDK script URL (default /integrations/universal/fikiri-sdk.js, proxied to Flask in dev)
# VITE_CHATBOT_SDK_URL=http://localhost:5000/integrations/universal/fikiri-sdk.js

# Subscription gate (Layout): production shows “subscribe / consulting” until active or trialing Stripe sub.
# Local dev: gate is off unless you set VITE_ENABLE_SUBSCRIPTION_GATE=true
# VITE_ENABLE_SUBSCRIPTION_GATE=true
# Production: set to disable the gate entirely (e.g. internal demo)
# VITE_DISABLE_SUBSCRIPTION_GATE=true
